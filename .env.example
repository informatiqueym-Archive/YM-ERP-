# ─────────────────────────────────────────────────────────────────
# YM-TRANSIT ERP — Variables d'environnement pour Coolify
# Définissez ces variables dans Coolify : Service → Environment Variables
# ─────────────────────────────────────────────────────────────────

# Clé API Gemini — obtenez la vôtre gratuitement sur aistudio.google.com/apikey
GEMINI_API_KEY=votre_cle_gemini_ici

# URL publique de l'application (sans barre oblique finale)
# Coolify l'injecte automatiquement — mettez à jour après le premier déploiement
APP_URL=https://votre-app.votre-domaine.com

# Base de données — chemin absolu dans le volume Docker persistant
# NE PAS MODIFIER — doit correspondre au volume Docker configuré dans Coolify
DATABASE_URL=file:/app/data/prod.db

# Port — Coolify le détecte automatiquement depuis EXPOSE dans le Dockerfile
PORT=3000

# Secret de session — changez ceci pour une longue chaîne aléatoire !
# Pour en générer une : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=changez-ceci-pour-une-longue-chaine-aleatoire-secrete

# Chemin des fichiers uploadés dans le conteneur Docker
UPLOADS_PATH=/app/uploads
