<%- include('../../partials/header') %>

<div class="mb-4">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="/dashboard">Accueil</a></li>
      <li class="breadcrumb-item"><a href="/admin/users">Utilisateurs</a></li>
      <li class="breadcrumb-item active" aria-current="page">Nouveau collaborateur</li>
    </ol>
  </nav>
  <h1 class="h2 font-display text-slate-800">Enregistrer un Collaborateur</h1>
  <p class="text-muted">Créez un nouveau compte d'accès ERP. Un mot de passe temporaire sera exigé pour sa première visite.</p>
</div>

<div class="row">
  <div class="col-lg-8">
    <div class="card border-0 shadow-sm rounded-3">
      <form action="/admin/users/create" method="POST" class="card-body p-4">
        <h5 class="card-title text-slate-800 fw-bold border-bottom pb-2 mb-4"><i class="bi bi-person-plus me-2"></i>Informations personnelles & d'accès</h5>
        
        <div class="row mb-3">
          <div class="col-md-6 mb-3 mb-md-0">
            <label class="form-label fw-semibold">Nom de famille <span class="text-danger">*</span></label>
            <div class="input-group">
              <span class="input-group-text bg-white text-muted"><i class="bi bi-person"></i></span>
              <input type="text" name="nom" class="form-control" placeholder="Ex: NYAMBA" required>
            </div>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-semibold">Prénom</label>
            <div class="input-group">
              <span class="input-group-text bg-white text-muted"><i class="bi bi-person"></i></span>
              <input type="text" name="prenom" class="form-control" placeholder="Ex: Jean-Luc">
            </div>
          </div>
        </div>

        <div class="row mb-3">
          <div class="col-md-6 mb-3 mb-md-0">
            <label class="form-label fw-semibold">Adresse Email <span class="text-danger">*</span></label>
            <div class="input-group">
              <span class="input-group-text bg-white text-muted"><i class="bi bi-envelope"></i></span>
              <input type="email" name="email" class="form-control" placeholder="Ex: jl.nyamba@bana-group.com" required>
            </div>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-semibold">Société / Entité <span class="text-danger">*</span></label>
            <div class="input-group">
              <span class="input-group-text bg-white text-muted"><i class="bi bi-building"></i></span>
              <input type="text" name="societe" class="form-control" placeholder="Ex: BANA Logistics" value="BANA Logistics" required>
            </div>
          </div>
        </div>

        <div class="row mb-4">
          <div class="col-md-6 mb-3 mb-md-0">
            <label class="form-label fw-semibold">Niveau d'accès / Rôle ERP <span class="text-danger">*</span></label>
            <div class="input-group">
              <span class="input-group-text bg-white text-muted"><i class="bi bi-shield-lock"></i></span>
              <select name="role" class="form-select" required>
                <option value="operationnel" selected>Operational - Tâches, Tiers & Dossiers uniquement</option>
                <option value="commercial">Commercial - Ventes, Facturation client & Analytics</option>
                <option value="comptable">Comptable - Grand Livre, Balance & Fournisseurs</option>
                <option value="magasinier">Magasinier - Stocks & Achats</option>
                <option value="rh">Ressources Humaines (RH)</option>
                <option value="super_admin">Super Administrateur - Tout accès + Gestion Comptes</option>
                <option value="lecture">Lecture seule (Auditeur) - Aucun droit de modification</option>
              </select>
            </div>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-semibold">Mot de passe temporaire <span class="text-danger">*</span></label>
            <div class="input-group">
              <span class="input-group-text bg-white text-muted"><i class="bi bi-key"></i></span>
              <input type="password" name="password" class="form-control" placeholder="Saisir un mot de passe de base" value="Bana@Password2024" required>
            </div>
            <div class="form-text text-muted">L'utilisateur sera obligé de le changer dès la première connexion.</div>
          </div>
        </div>

        <div class="d-flex justify-content-end gap-2 border-top pt-4">
          <a href="/admin/users" class="btn btn-outline-secondary rounded-pill px-4">Annuler</a>
          <button type="submit" class="btn btn-primary rounded-pill px-4 shadow-sm">
            <i class="bi bi-check-circle me-2"></i>Enregistrer le collaborateur
          </button>
        </div>
      </form>
    </div>
  </div>

  <div class="col-lg-4">
    <div class="card border-0 bg-info-subtle text-info-emphasis shadow-sm rounded-3">
      <div class="card-body p-4">
        <h5 class="fw-bold mb-3"><i class="bi bi-info-circle-fill me-2"></i>Permissions des Rôles</h5>
        <ul class="list-unstyled mb-0 d-flex flex-column gap-3">
          <li>
            <strong class="text-dark">Super Admin :</strong>
            <p class="mb-0 small">Accès complet à la totalité de la plateforme y compris la journalisation et l'administration des utilisateurs de l'entreprise.</p>
          </li>
          <li>
            <strong class="text-dark">Comptable :</strong>
            <p class="mb-0 small">Accès aux modules Comptabilité, Chats & Fournisseurs, Devis & Facturation clients, Stocks et Analytics.</p>
          </li>
          <li>
            <strong class="text-dark">Commercial :</strong>
            <p class="mb-0 small">Gère le portefeuille clients, réalise la facturation client, suit les dossiers de transit et accède aux rapports analytiques.</p>
          </li>
          <li>
            <strong class="text-dark">Opérationnel :</strong>
            <p class="mb-0 small">Concentration sur la logistique : fiches clients, suivi opérationnel des dossiers de transit et pilotage des tâches.</p>
          </li>
          <li>
            <strong class="text-dark">Lecture seule (Auditeur) :</strong>
            <p class="mb-0 small">Peut explorer l'ensemble de l'ERP à des fins de contrôle comptable ou d'audit sans pouvoir faire de modification (POST/PATCH désactivés).</p>
          </li>
        </ul>
      </div>
    </div>
  </div>
</div>

<%- include('../../partials/footer') %>
